# 环境变量配置
# 复制此文件为 .env 并填入实际值

# MySQL 数据库连接字符串
# 格式: mysql://用户名:密码@主机:端口/数据库名?ssl-mode=REQUIRED
DATABASE_URL=mysql://user:pass@mysql-host.example.com:3306/bookmarks?ssl-mode=REQUIRED

# ========================================
# AI（可选，建议仅 Docker 主站开启）
# ========================================
AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
AI_TIMEOUT_MS=8000

# 可选：覆盖内置系统提示词（建议保持“两行输出 tags/summary”的规则，否则解析可能失败）
# AI_SYSTEM_PROMPT=你是一个书签整理助手。输出必须且只能包含两行：tags: ...\\nsummary: ...

# 是否允许前端传入/覆盖（自用场景可选；对外暴露站点不建议开启）
AI_ALLOW_CLIENT_KEY=false
AI_ALLOW_CLIENT_BASE_URL=false
AI_ALLOW_CLIENT_PROVIDER=false
AI_ALLOW_PRIVATE_BASE_URL=false

# OpenAI
OPENAI_API_KEY=

# Gemini（Google）
GEMINI_API_KEY=

# Claude（Anthropic）
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
