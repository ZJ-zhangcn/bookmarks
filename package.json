{
  "name": "bookmark-nav",
  "version": "1.0.0",
  "description": "书签导航 - 支持 Docker 部署",
  "scripts": {
    "dev": "cd backend && node server.js",
    "dev:frontend": "cd frontend && npx vite",
    "build": "echo 'No build step required'",
    "build:frontend": "cd frontend && npx vite build",
    "preview": "cd frontend && npx vite preview",
    "lint": "eslint frontend/modules backend shared",
    "lint:fix": "eslint frontend/modules backend shared --fix",
    "test": "node --test tests/*.test.js",
    "audit:high": "npm audit --audit-level=high",
    "db:init": "node scripts/init-mysql.js",
    "db:migrate": "node scripts/migrate-to-mysql.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.1.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mysql2": "^3.11.0",
    "undici": "^6.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "eslint": "^8.57.1",
    "globals": "^15.15.0",
    "vite": "^7.3.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
