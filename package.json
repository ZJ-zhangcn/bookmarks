{
  "name": "bookmark-nav",
  "version": "1.0.0",
  "description": "书签导航 - 支持 Docker 部署",
  "scripts": {
    "dev": "cd backend && node server.js",
    "dev:frontend": "cd frontend && npx vite",
    "build": "echo 'No build step required'",
    "build:frontend": "cd frontend && npx vite build",
    "preview": "cd frontend && npx vite preview",
    "lint": "npx eslint frontend/modules/ backend/ shared/ --ext .js",
    "lint:fix": "npx eslint frontend/modules/ backend/ shared/ --ext .js --fix",
    "db:init": "node scripts/init-mysql.js",
    "db:migrate": "node scripts/migrate-to-mysql.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.1.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mysql2": "^3.11.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
