{
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "indent": ["warn", 4, { "SwitchCase": 1 }],
    "no-multiple-empty-lines": ["warn", { "max": 2 }],
    "eqeqeq": ["warn", "smart"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-undef": "error"
  },
  "globals": {
    "i18n": "readonly"
  },
  "ignorePatterns": ["node_modules/", "data/"]
}
